# Copy this file to .env and change the values (especially SECRET_KEY) before deploying.

# Database (Postgres)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/user_management

# JWT
SECRET_KEY=change-this-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=5
REFRESH_TOKEN_EXPIRE_DAYS=2

# Google Sign-In
# Create this in Google Cloud Console -> APIs & Services -> Credentials ->
# "Create Credentials" -> "OAuth client ID" -> Web application.
# Add your frontend's origin(s) under "Authorized JavaScript origins".
GOOGLE_CLIENT_ID=407408718192.apps.googleusercontent.com


# Only needed for POST /auth/google/authorize (exchanging a native-SDK
# serverAuthCode for a Google refresh token). Not needed for plain
# ID-token sign-in via POST /auth/google. From the same Web application
# client as GOOGLE_CLIENT_ID above -- never send this to any frontend.
GOOGLE_CLIENT_SECRET=GOCSPX-client-secret-key

# Fernet key used to encrypt Google refresh tokens before storing them.
# Generate with:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
GOOGLE_TOKEN_ENCRYPTION_KEY='Qjclientencryptionkey='
